{
  "name": "com.example.markdown-pro",
  "version": "1.6.2",
  "private": true,
  "description": "A polished Markdown editor plugin for Standard Notes",
  "sn": {
    "name": "Markdown Pro",
    "content_type": "SN|Component",
    "area": "editor-editor",
    "spellcheckControl": true,
    "note_type": "markdown",
    "file_type": "md",
    "main": "dist/index.html",
    "showInGallery": true
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@codemirror/commands": "^6.7.0",
    "@codemirror/lang-markdown": "^6.3.0",
    "@codemirror/language": "^6.10.0",
    "@codemirror/language-data": "^6.5.0",
    "@codemirror/search": "^6.5.0",
    "@codemirror/state": "^6.4.0",
    "@codemirror/view": "^6.34.0",
    "@lezer/highlight": "^1.2.0",
    "@standardnotes/component-relay": "standardnotes/component-relay#893561d2dc72cd3c66f071b3a509b8b7dcd721de",
    "dompurify": "^3.2.0",
    "highlight.js": "^11.10.0",
    "katex": "^0.16.11",
    "marked": "^14.0.0",
    "marked-highlight": "^2.2.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
